{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Ljudi iza Avangarde"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "fullName": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "fullName", "required": true },
    "role": { "type": "string", "required": true },
    "role_en": { "type": "string" },
    "role_tr": { "type": "string" },
    "role_fr": { "type": "string" },
    "role_de": { "type": "string" },
    "shortBio": { "type": "text", "required": true },
    "shortBio_en": { "type": "text" },
    "shortBio_tr": { "type": "text" },
    "shortBio_fr": { "type": "text" },
    "shortBio_de": { "type": "text" },
    "longBio": { "type": "richtext" },
    "longBio_en": { "type": "richtext" },
    "longBio_tr": { "type": "richtext" },
    "longBio_fr": { "type": "richtext" },
    "longBio_de": { "type": "richtext" },
    "portrait": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "email": { "type": "email" },
    "website": { "type": "string" },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social"
    },
    "location": { "type": "string" },
    "location_en": { "type": "string" },
    "location_tr": { "type": "string" },
    "location_fr": { "type": "string" },
    "location_de": { "type": "string" },
    "languages": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-tag"
    },
    "skills": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-tag"
    },
    "education": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "experience": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "projects": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "publications": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "certifications": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "trainings": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "awards": {
      "type": "component",
      "repeatable": true,
      "component": "people.portfolio-entry"
    },
    "customSections": {
      "type": "component",
      "repeatable": true,
      "component": "people.custom-section"
    },
    "relatedArticles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article"
    },
    "cvFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "portfolioEnabled": {
      "type": "boolean",
      "default": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  }
}
