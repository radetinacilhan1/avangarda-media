# Copy this to .env and replace values
MEILI_MASTER_KEY=change_me

STRAPI_JWT_SECRET=change_me
STRAPI_ADMIN_JWT_SECRET=change_me
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=change_me
CONTRIBUTE_RECIPIENT_EMAIL=
CONTRIBUTE_SUBMISSION_READY=false

# You will paste a real token here after you create it in Strapi Admin
STRAPI_WORKER_TOKEN=will_add_later

PLAUSIBLE_DOMAIN=local

# Frontend production variables
# Example:
# NEXT_PUBLIC_SITE_URL=https://avangarda.media
# NEXT_PUBLIC_STRAPI_URL=https://cms.avangarda.media
# NEXT_PUBLIC_STRAPI_PUBLIC_URL=https://cms.avangarda.media

# Server-side production variables (optional but recommended)
# STRAPI_URL=https://cms.avangarda.media
